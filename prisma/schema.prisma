generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String
  website      String?
  linkedin     String?
  notes        String?
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])

  roleTitle String
  roleLevel String?
  jobUrl    String?
  salary    String?
  location  String?
  workType  String?

  stage    String   @default("APPLIED")
  source   String?
  priority String   @default("MEDIUM")

  rawJd     String?

  rejectReason String?
  followUpDate DateTime?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files    ApplicationFile[]
  events   ApplicationEvent[]
  contacts Contact[]
  notes    Note[]
}

model ApplicationFile {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type       String
  label      String?
  filename   String
  storedPath String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
}

model ApplicationEvent {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  eventType   String
  title       String?
  description String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
}

model Contact {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  name            String
  role            String?
  email           String?
  linkedin        String?
  notes           String?
  lastContactedAt DateTime?
}

model Note {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
